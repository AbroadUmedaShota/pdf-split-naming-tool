{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PDF整理ツール",
  "version": "0.1.5",
  "identifier": "com.local.pdf-organizer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build:bundle",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "PDF整理ツール",
        "width": 1280,
        "height": 860,
        "minWidth": 1200,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": "default-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"],
    "resources": ["resources/sidecar/"],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE3ODIwRTA5OUM2QzhCMTgKUldRWWkyeWNDUTZDRngzRS9pMll4QVdwMThXaDRlQXdoNWVKWElwa1A1VmRRaldoa2dPVmRHVDgK",
      "endpoints": [
        "https://github.com/AbroadUmedaShota/pdf-split-naming-tool/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
