{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PDF整理ツール",
  "version": "0.1.0",
  "identifier": "com.local.pdf-organizer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "title": "PDF整理ツール",
        "width": 1280,
        "height": 860,
        "minWidth": 1024,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
